<UserControl x:Class="RAM.UI.Controls.WorkerStateBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RAM.Core.Models;assembly=RAM.Core"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root">
    <!-- Compact pill that surfaces the auto-rejoin worker FSM state next to the row title.
         Hidden in Idle (the common case before launch). Watching/GracePeriod/Rejoining/Error
         each get their own color + icon + tooltip via per-element DataTriggers (Style
         setters can't set TargetName, so each child styles itself off the same source). -->
    <Border BorderThickness="1"
            CornerRadius="999"
            Padding="6,1"
            VerticalAlignment="Center">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                 Value="{x:Static models:RejoinWorkerState.Watching}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Setter Property="BorderBrush" Value="{DynamicResource StatusInGame}" />
                        <Setter Property="ToolTip" Value="Auto-rejoin is watching this account" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                 Value="{x:Static models:RejoinWorkerState.GracePeriod}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Setter Property="BorderBrush" Value="{DynamicResource StatusPremium}" />
                        <Setter Property="ToolTip" Value="Disconnect detected — waiting before relaunch" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                 Value="{x:Static models:RejoinWorkerState.Rejoining}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                        <Setter Property="ToolTip" Value="Auto-rejoin is relaunching this account" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                 Value="{x:Static models:RejoinWorkerState.Error}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Setter Property="BorderBrush" Value="{DynamicResource StatusError}" />
                        <Setter Property="ToolTip" Value="Auto-rejoin launch failed — manual relaunch required" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel Orientation="Horizontal">
            <Path Stretch="Uniform" Width="9" Height="9"
                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  VerticalAlignment="Center">
                <Path.Style>
                    <Style TargetType="Path">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.Watching}">
                                <Setter Property="Data" Value="{StaticResource IconCheck}" />
                                <Setter Property="Stroke" Value="{DynamicResource StatusInGame}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.GracePeriod}">
                                <Setter Property="Data" Value="{StaticResource IconClock}" />
                                <Setter Property="Stroke" Value="{DynamicResource StatusPremium}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.Rejoining}">
                                <Setter Property="Data" Value="{StaticResource IconRefresh}" />
                                <Setter Property="Stroke" Value="{DynamicResource Accent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.Error}">
                                <Setter Property="Data" Value="{StaticResource IconAlert}" />
                                <Setter Property="Stroke" Value="{DynamicResource StatusError}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Path.Style>
            </Path>
            <TextBlock Margin="4,0,0,0"
                       FontSize="10"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.Watching}">
                                <Setter Property="Text" Value="watching" />
                                <Setter Property="Foreground" Value="{DynamicResource StatusInGame}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.GracePeriod}">
                                <Setter Property="Text" Value="grace" />
                                <Setter Property="Foreground" Value="{DynamicResource StatusPremium}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.Rejoining}">
                                <Setter Property="Text" Value="rejoining" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WorkerState, ElementName=Root}"
                                         Value="{x:Static models:RejoinWorkerState.Error}">
                                <Setter Property="Text" Value="failed" />
                                <Setter Property="Foreground" Value="{DynamicResource StatusError}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>

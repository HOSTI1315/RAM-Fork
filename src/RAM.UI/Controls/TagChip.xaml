<UserControl x:Class="RAM.UI.Controls.TagChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root">
    <Border Background="{DynamicResource BgElevated}"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="999"
            Padding="8,1">
        <TextBlock Text="{Binding Text, ElementName=Root}"
                   FontSize="{DynamicResource Fs11}"
                   Foreground="{DynamicResource FgSecondary}"
                   VerticalAlignment="Center" />
    </Border>
</UserControl>

<UserControl x:Class="RAM.UI.Controls.AvatarWithStatus"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RAM.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root"
             Width="36" Height="36">
    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
        <conv:InitialLetterConverter x:Key="InitialLetter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Striped placeholder background (port of avatar.placeholder repeating-linear-gradient).
             Color isn't theme-perfect for light theme but stays subtle either way. -->
        <Border Background="{DynamicResource BgElevated}"
                CornerRadius="{DynamicResource RadiusMd}"
                ClipToBounds="True">
            <Border.OpacityMask>
                <DrawingBrush TileMode="Tile" ViewportUnits="Absolute" Viewport="0,0,8,8"
                              Stretch="None">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#22FFFFFF">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,4,8" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Border.OpacityMask>
        </Border>

        <!-- Initial letter (centered) -->
        <TextBlock Text="{Binding Username, ElementName=Root, Converter={StaticResource InitialLetter}}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="{DynamicResource Fs12}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource FgSecondary}" />

        <!-- Premium ring overlay -->
        <Border BorderBrush="{DynamicResource StatusPremium}" BorderThickness="2"
                CornerRadius="{DynamicResource RadiusMd}"
                Margin="-2"
                IsHitTestVisible="False"
                Visibility="{Binding HasPremium, ElementName=Root, Converter={StaticResource BoolToVis}}" />

        <!-- Discord-style avatar status overlay: 14px dot, ringed by surface color
             (parent's bg). The ring color is provided by SurfaceBrush dependency property
             so callers can match BgSecondary / BgHover / BgSelected per row state. -->
        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,-2,-2"
              Width="14" Height="14"
              Visibility="{Binding ShowStatus, ElementName=Root, Converter={StaticResource BoolToVis}}">
            <Ellipse Fill="{Binding SurfaceBrush, ElementName=Root}" />
            <Ellipse Margin="3"
                     Fill="{Binding Status, ElementName=Root, Converter={StaticResource StatusToBrush}}" />
        </Grid>
    </Grid>
</UserControl>

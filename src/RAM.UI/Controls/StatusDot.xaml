<UserControl x:Class="RAM.UI.Controls.StatusDot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RAM.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root">
    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
    </UserControl.Resources>
    <!-- Inline 8px dot, no halo. Used inside text rows ("· Online"). For the Discord-style
         avatar overlay dot with surface ring, see AvatarWithStatus. -->
    <Ellipse Width="8" Height="8"
             Fill="{Binding Status, ElementName=Root, Converter={StaticResource StatusToBrush}}" />
</UserControl>

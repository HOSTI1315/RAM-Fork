<UserControl x:Class="RAM.UI.Views.Dialogs.AddAccountDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RAM.App.ViewModels;assembly=RAM.App"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AddAccountViewModel}"
             Width="540">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- header -->
            <RowDefinition Height="Auto" />
            <!-- tabs -->
            <RowDefinition Height="*" />
            <!-- body -->
            <RowDefinition Height="Auto" />
            <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Add account"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgPrimary}" />
                <TextBlock Text="Sign in by cookie, password, or paste a list."
                           FontSize="12"
                           Foreground="{DynamicResource FgSecondary}"
                           Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}"
                    Command="{Binding CancelCommand}"
                    ToolTip="Cancel (Esc)"
                    VerticalAlignment="Top">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1.4" Width="10" Height="10" />
            </Button>
        </Grid>

        <!-- Tab strip -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgInput}"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="2"
                Margin="0,0,0,12"
                HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton GroupName="AddTab" Grid.Column="0"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=0}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Cookie" />
                <RadioButton GroupName="AddTab" Grid.Column="1"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=1}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Username · Password" />
                <RadioButton GroupName="AddTab" Grid.Column="2"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=2}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Bulk import" />
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">

            <!-- Tab 0: Cookie -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=0}">
                <TextBlock Text=".ROBLOSECURITY cookie"
                           FontSize="11" Foreground="{DynamicResource FgTertiary}"
                           Margin="0,0,0,4" />
                <Border Background="{DynamicResource BgInput}"
                        BorderBrush="{DynamicResource BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMd}">
                    <TextBox Text="{Binding CookieValue, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource FgPrimary}"
                             FontFamily="{DynamicResource FontMono}" FontSize="12"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="80" Padding="12,8"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto" />
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock FontSize="11" Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,4">
                            <Run Text="Alias " /><Run Text="(optional)" Foreground="{DynamicResource FgTertiary}" />
                        </TextBlock>
                        <TextBox Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="Group" FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,4" />
                        <ComboBox IsEditable="True"
                                  Text="{Binding Group, UpdateSourceTrigger=LostFocus}"
                                  ItemsSource="{Binding AvailableGroups}"
                                  Background="{DynamicResource BgInput}"
                                  BorderBrush="{DynamicResource BorderDefault}"
                                  Foreground="{DynamicResource FgPrimary}"
                                  Height="30" />
                    </StackPanel>
                </Grid>

                <Border Background="{DynamicResource BgInput}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMd}"
                        Padding="12,8" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔒" FontSize="14" Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Top" Margin="0,1,8,0" />
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource FgSecondary}"
                                   Text="The cookie is encrypted at rest in your local profile (Argon2id + XSalsa20-Poly1305). RAM never transmits it." />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Tab 1: Username · Password (with 2FA sub-state) -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=1}">
                <!-- Pass form (visible unless TwoFactor required) -->
                <StackPanel Visibility="{Binding TwoFactorVisible, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <TextBlock Text="Username" FontSize="11"
                               Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,12" />

                    <TextBlock Text="Password" FontSize="11"
                               Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource BgInput}"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource RadiusMd}"
                            Height="30"
                            Margin="0,0,0,12">
                        <PasswordBox x:Name="PasswordField"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource FgPrimary}"
                                     CaretBrush="{DynamicResource FgPrimary}"
                                     FontSize="13"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="OnPasswordChanged" />
                    </Border>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock FontSize="11" Foreground="{DynamicResource FgTertiary}"
                                       Margin="0,0,0,4">
                                <Run Text="Alias " /><Run Text="(optional)" />
                            </TextBlock>
                            <TextBox Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Group" FontSize="11"
                                       Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                            <ComboBox IsEditable="True"
                                      Text="{Binding Group, UpdateSourceTrigger=LostFocus}"
                                      ItemsSource="{Binding AvailableGroups}"
                                      Background="{DynamicResource BgInput}"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      Foreground="{DynamicResource FgPrimary}"
                                      Height="30" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- 2FA sub-form (Step 7.4.4) -->
                <StackPanel Visibility="{Binding TwoFactorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Two-factor required"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgPrimary}"
                               Margin="0,0,0,4" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource FgSecondary}"
                               Margin="0,0,0,12">
                        <Run Text="Signing in as " />
                        <Run Text="{Binding Username, Mode=OneWay}"
                             FontFamily="{DynamicResource FontMono}"
                             Foreground="{DynamicResource FgPrimary}" />
                    </TextBlock>

                    <TextBlock Text="Verification method"
                               FontSize="11" Foreground="{DynamicResource FgTertiary}"
                               Margin="0,0,0,4" />
                    <ComboBox SelectedItem="{Binding TwoFactorMediaType}"
                              ItemsSource="{Binding AvailableTwoFactorMediaTypes}"
                              Background="{DynamicResource BgInput}"
                              BorderBrush="{DynamicResource BorderDefault}"
                              Foreground="{DynamicResource FgPrimary}"
                              Height="30"
                              Margin="0,0,0,12" />

                    <TextBlock Text="6-digit code" FontSize="11"
                               Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource BgInput}"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource RadiusMd}"
                            Margin="0,0,0,12">
                        <TextBox Text="{Binding TwoFactorCode, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="8"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource FgPrimary}"
                                 FontFamily="{DynamicResource FontMono}"
                                 FontSize="16"
                                 Padding="12,8"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Tab 2: Bulk import -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=2}">
                <!-- File-drop zone — drag a .json or click to browse -->
                <Border x:Name="DropZone"
                        AllowDrop="True"
                        Drop="OnFileDrop"
                        DragOver="OnDragOver"
                        Background="{DynamicResource BgInput}"
                        BorderBrush="{DynamicResource BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMd}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock TextAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource FgSecondary}">
                            <Run Text="Drop a " />
                            <Run Text=".json"
                                 FontFamily="{DynamicResource FontMono}"
                                 Foreground="{DynamicResource FgPrimary}" />
                            <Run Text=" file here, or" />
                        </TextBlock>
                        <Button Style="{StaticResource BtnStyle}"
                                Command="{Binding PickBulkFileCommand}"
                                Content="Choose file…"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0" />
                        <TextBlock TextAlignment="Center" FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding BulkFileImportPath, Converter={StaticResource NullToVis}}">
                            <Run Text="Loaded: " />
                            <Run Text="{Binding BulkFileImportPath, Mode=OneWay}"
                                 FontFamily="{DynamicResource FontMono}"
                                 Foreground="{DynamicResource FgPrimary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Preview list (visible only when file was loaded) -->
                <Border Background="{DynamicResource BgInput}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMd}"
                        Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding BulkFilePreviewVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="{DynamicResource FgPrimary}">
                            <Run Text="Preview: " />
                            <Run Text="{Binding BulkFilePreviewCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" account(s)" />
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding BulkFilePreviewNames}"
                                       Margin="0,6,0,0"
                                       MaxHeight="100">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="{DynamicResource FontMono}"
                                               FontSize="11"
                                               Foreground="{DynamicResource FgSecondary}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                        </ItemsControl>
                        <TextBlock Text="{Binding BulkFileImportWarning}"
                                   FontSize="11"
                                   Foreground="{DynamicResource StatusPremium}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding BulkFileImportWarning, Converter={StaticResource NullToVis}}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="Or paste cookies — one per line"
                           FontSize="11" Foreground="{DynamicResource FgTertiary}"
                           Margin="0,0,0,4" />
                <Border Background="{DynamicResource BgInput}"
                        BorderBrush="{DynamicResource BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMd}">
                    <TextBox Text="{Binding BulkCookies, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource FgPrimary}"
                             FontFamily="{DynamicResource FontMono}"
                             FontSize="11"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             MinHeight="140" Padding="12,8"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Default group"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                        <ComboBox IsEditable="True"
                                  Text="{Binding Group, UpdateSourceTrigger=LostFocus}"
                                  ItemsSource="{Binding AvailableGroups}"
                                  Background="{DynamicResource BgInput}"
                                  BorderBrush="{DynamicResource BorderDefault}"
                                  Foreground="{DynamicResource FgPrimary}"
                                  Height="30"
                                  Width="220"
                                  HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right">
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   FontFamily="{DynamicResource FontMono}"
                                   Visibility="{Binding BulkInProgress, Converter={StaticResource BoolToVis}}">
                            <Run Text="Validated: " />
                            <Run Text="{Binding BulkValidatedCount, Mode=OneWay}" Foreground="{DynamicResource StatusOnline}" />
                            <Run Text="  Failed: " />
                            <Run Text="{Binding BulkFailedCount, Mode=OneWay}" Foreground="{DynamicResource StatusError}" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Error message overlay (visible when ErrorMessage set) -->
            <Border VerticalAlignment="Bottom"
                    Background="#1AF23F43"
                    BorderBrush="#4DF23F43"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource RadiusMd}"
                    Padding="12,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource FgPrimary}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="🛡  Local-only · encrypted at rest"
                           FontSize="11"
                           Foreground="{DynamicResource FgTertiary}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource BtnStyle}"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        IsCancel="True"
                        Margin="0,0,8,0" />

                <!-- Primary submit — content/command varies by tab and 2FA state -->
                <Button Grid.Column="2" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BtnPrimaryStyle}">
                            <Setter Property="Content" Value="Validate &amp; add" />
                            <Setter Property="Command" Value="{Binding SubmitCookieCommand}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                    <Setter Property="Content" Value="Sign in" />
                                    <Setter Property="Command" Value="{Binding SubmitPasswordCommand}" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding SelectedTabIndex}" Value="1" />
                                        <Condition Binding="{Binding TwoFactorVisible}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Content" Value="Verify" />
                                    <Setter Property="Command" Value="{Binding SubmitTwoFactorCommand}" />
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                    <Setter Property="Content" Value="Import all" />
                                    <Setter Property="Command" Value="{Binding SubmitBulkCommand}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

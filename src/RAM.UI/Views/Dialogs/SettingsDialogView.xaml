<UserControl x:Class="RAM.UI.Views.Dialogs.SettingsDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RAM.App.ViewModels;assembly=RAM.App"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             Width="560">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Settings"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgPrimary}" />
                <TextBlock Text="Per-install configuration. Persisted to RAMSettings.ini."
                           FontSize="12"
                           Foreground="{DynamicResource FgSecondary}"
                           Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}"
                    Command="{Binding DataContext.CloseDialogCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="Close (Esc)"
                    VerticalAlignment="Top">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1.4" Width="10" Height="10" />
            </Button>
        </Grid>

        <!-- Body — scrollable -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      MaxHeight="420">
            <StackPanel>

                <!-- Launcher -->
                <TextBlock Text="LAUNCHER"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,0,0,8" />
                <CheckBox IsChecked="{Binding MultiInstanceEnabled}"
                          Foreground="{DynamicResource FgPrimary}"
                          FontSize="13" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Multi-instance enabled" />
                        <TextBlock Text="Bypass ROBLOX_singletonMutex so multiple Roblox processes can run."
                                   FontSize="11" Foreground="{DynamicResource FgTertiary}" />
                    </StackPanel>
                </CheckBox>
                <CheckBox IsChecked="{Binding CookieFileLockEnabled}"
                          Foreground="{DynamicResource FgPrimary}"
                          FontSize="13" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Cookie file lock (773 fix)" />
                        <TextBlock Text="Prevents Roblox launcher from clobbering cookies during parallel launches."
                                   FontSize="11" Foreground="{DynamicResource FgTertiary}" />
                    </StackPanel>
                </CheckBox>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Default profile"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding DefaultProfile}"
                              Background="{DynamicResource BgInput}"
                              BorderBrush="{DynamicResource BorderDefault}"
                              Foreground="{DynamicResource FgPrimary}"
                              Height="30" />
                </Grid>

                <!-- Auto-rejoin -->
                <TextBlock Text="AUTO-REJOIN"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,4" />
                <TextBlock Text="Changes apply on next account launch — running watchers keep their original snapshot until the next manual launch."
                           FontSize="11"
                           Foreground="{DynamicResource FgTertiary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Check interval (s)"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding RejoinCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontFamily="{DynamicResource FontMono}" />
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Grace period (s)"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding RejoinGracePeriodSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontFamily="{DynamicResource FontMono}" />
                </Grid>

                <!-- Watcher -->
                <TextBlock Text="WATCHER"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Memory threshold (MiB)"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding MemoryThresholdMb, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontFamily="{DynamicResource FontMono}" />
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Window-title check (s)"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding WindowTitleCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontFamily="{DynamicResource FontMono}" />
                </Grid>

                <!-- Storage -->
                <TextBlock Text="STORAGE"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,8" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Backup retention (h)"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding BackupRetentionHours, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontFamily="{DynamicResource FontMono}" />
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Export accounts" FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                        <TextBlock Text="Plaintext JSON · cleartext cookies"
                                   FontSize="11" Foreground="{DynamicResource StatusError}" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource BtnStyle}"
                            Command="{Binding ExportCommand}"
                            HorizontalAlignment="Left"
                            Content="Export…" />
                </Grid>

                <!-- Network -->
                <TextBlock Text="NETWORK"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Default proxy"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding DefaultProxy, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontFamily="{DynamicResource FontMono}" />
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Presence provider"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailablePresenceProviders}"
                              SelectedItem="{Binding PresenceProvider}"
                              Background="{DynamicResource BgInput}"
                              BorderBrush="{DynamicResource BorderDefault}"
                              Foreground="{DynamicResource FgPrimary}"
                              Height="30" />
                </Grid>

                <!-- Logging -->
                <TextBlock Text="LOGGING"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,8" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Level"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgSecondary}" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableLogLevels}"
                              SelectedItem="{Binding LogLevel}"
                              Background="{DynamicResource BgInput}"
                              BorderBrush="{DynamicResource BorderDefault}"
                              Foreground="{DynamicResource FgPrimary}"
                              Height="30" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource FgTertiary}"
                           Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}">
                    unsaved changes
                </TextBlock>
                <Button Grid.Column="1" Style="{StaticResource BtnStyle}"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        IsCancel="True"
                        Margin="0,0,8,0" />
                <Button Grid.Column="2" Style="{StaticResource BtnPrimaryStyle}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsDirty}"
                        IsDefault="True"
                        Content="Save" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

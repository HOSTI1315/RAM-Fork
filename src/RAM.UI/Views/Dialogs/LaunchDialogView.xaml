<UserControl x:Class="RAM.UI.Views.Dialogs.LaunchDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RAM.App.ViewModels;assembly=RAM.App"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LaunchDialogViewModel}"
             Width="540">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Launch"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgPrimary}" />
                <TextBlock Text="{Binding AccountLabel}"
                           FontSize="12"
                           Foreground="{DynamicResource FgSecondary}"
                           Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}"
                    Command="{Binding CancelCommand}"
                    ToolTip="Cancel (Esc)"
                    VerticalAlignment="Top">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1.4" Width="10" Height="10" />
            </Button>
        </Grid>

        <!-- Tab strip -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgInput}"
                CornerRadius="{DynamicResource RadiusMd}"
                Padding="2"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton GroupName="LaunchTab" Grid.Column="0"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=0}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Place ID" />
                <RadioButton GroupName="LaunchTab" Grid.Column="1"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=1}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Job ID" />
                <RadioButton GroupName="LaunchTab" Grid.Column="2"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=2}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Follow user" />
                <RadioButton GroupName="LaunchTab" Grid.Column="3"
                             IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=3}"
                             Style="{StaticResource SegmentedTabStyle}"
                             Content="Private server" />
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">

            <!-- Tab 0: Place ID -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=0}">
                <TextBlock Text="Place ID" FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding PlaceId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}" />
                <TextBlock Text="Joins any available server for this place."
                           FontSize="11"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Tab 1: Job ID -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=1}">
                <TextBlock Text="Place ID" FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding JobPlaceId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}" Margin="0,0,0,12" />
                <TextBlock Text="Job ID" FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding JobId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}" />
                <TextBlock Text="Joins a specific server (gameId) instance of the place."
                           FontSize="11"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Tab 2: Follow user -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=2}">
                <TextBlock Text="Target user ID" FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding FollowUserId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}" />
                <TextBlock Text="Joins the place where this user is currently in (if any)."
                           FontSize="11"
                           Foreground="{DynamicResource FgTertiary}"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Tab 3: Private server -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntEqualsToVisibility}, ConverterParameter=3}">
                <TextBlock Text="Place ID" FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding PrivatePlaceId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}" Margin="0,0,0,12" />

                <TextBlock Text="Share link (optional — extracts code automatically)"
                           FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding PrivateLinkUrl, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}"
                         Margin="0,0,0,12" />

                <TextBlock Text="Or paste link code directly" FontSize="11"
                           Foreground="{DynamicResource FgTertiary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding PrivateLinkCode, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         FontFamily="{DynamicResource FontMono}" />
            </StackPanel>

            <!-- Error message -->
            <Border VerticalAlignment="Bottom"
                    Background="#1AF23F43"
                    BorderBrush="#4DF23F43"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource RadiusMd}"
                    Padding="12,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource FgPrimary}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Style="{StaticResource BtnStyle}"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        IsCancel="True"
                        Margin="0,0,8,0" />
                <Button Grid.Column="2" Style="{StaticResource BtnPrimaryStyle}"
                        Command="{Binding SubmitCommand}"
                        IsDefault="True"
                        Content="Launch" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

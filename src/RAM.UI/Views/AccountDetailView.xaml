<UserControl x:Class="RAM.UI.Views.AccountDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RAM.App.ViewModels;assembly=RAM.App"
             xmlns:ctrl="clr-namespace:RAM.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AccountDetailViewModel}"
             Background="{DynamicResource BgTertiary}">

    <!-- Detail panel. DataContext = AccountDetailViewModel. List-level commands
         (Launch / Refresh / Delete) reach AccountListViewModel via the Window's
         DataContext (ShellViewModel.AccountList). -->
    <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- header (avatar + name + close) -->
                <RowDefinition Height="Auto" />
                <!-- status row -->
                <RowDefinition Height="Auto" />
                <!-- actions row -->
                <RowDefinition Height="*" />
                <!-- scrollable body -->
            </Grid.RowDefinitions>

            <!-- header row: avatar + alias/username + close -->
            <Grid Grid.Row="0" Margin="16,16,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ctrl:AvatarWithStatus Grid.Column="0" Width="64" Height="64"
                                       Username="{Binding Username}"
                                       Status="{Binding DataContext.AccountList.SelectedItem.PresenceType,
                                                          RelativeSource={RelativeSource AncestorType=Window},
                                                          FallbackValue=Offline}"
                                       SurfaceBrush="{DynamicResource BgTertiary}"
                                       VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgPrimary}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11"
                               FontFamily="{DynamicResource FontMono}"
                               Foreground="{DynamicResource FgTertiary}"
                               Margin="0,2,0,0">
                        <Run Text="@" /><Run Text="{Binding Username, Mode=OneWay}" />
                        <Run Text=" · " />
                        <Run Text="{Binding UserId, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}"
                        ToolTip="Close detail (Esc)"
                        Command="{Binding DataContext.CloseDetailCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                        VerticalAlignment="Top">
                    <Path Data="M0,0 L10,10 M10,0 L0,10"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.4"
                          Width="10" Height="10" />
                </Button>
            </Grid>

            <!-- status row -->
            <Grid Grid.Row="1" Margin="16,4,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding DataContext.AccountList.SelectedItem.PresenceType,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource StatusToBrush},
                                            FallbackValue=Gray}" />
                    <TextBlock Margin="6,0,0,0"
                               Text="{Binding DataContext.AccountList.SelectedItem.PresenceType,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Converter={StaticResource PresenceLabel},
                                              FallbackValue=''}"
                               FontSize="12"
                               Foreground="{Binding DataContext.AccountList.SelectedItem.PresenceType,
                                                    RelativeSource={RelativeSource AncestorType=Window},
                                                    Converter={StaticResource StatusToBrush},
                                                    FallbackValue=Gray}"
                               VerticalAlignment="Center" />
                    <TextBlock Margin="8,0,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource FgTertiary}"
                               VerticalAlignment="Center">
                        <Run Text="·" />
                        <Run Text="{Binding DataContext.AccountList.SelectedItem.LastLocation,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Mode=OneWay,
                                            FallbackValue=''}" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="14" Height="14"
                            Background="{DynamicResource StatusPremium}"
                            CornerRadius="3"
                            VerticalAlignment="Center">
                        <TextBlock Text="R$"
                                   Foreground="#2A1F00"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding DataContext.AccountList.SelectedItem.Robux,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Converter={StaticResource NumberFormat},
                                              FallbackValue='—'}"
                               Margin="6,0,0,0"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="12"
                               Foreground="{DynamicResource FgPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- actions row: Launch / Refresh / Delete (per Step 7.3 user spec) -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource BtnPrimaryStyle}"
                            Command="{Binding DataContext.AccountList.LaunchCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding DataContext.AccountList.SelectedItem,
                                                        RelativeSource={RelativeSource AncestorType=Window}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlay}"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  Stretch="Uniform" Width="12" Height="12" />
                            <TextBlock Text="Launch" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BtnStyle}" Margin="6,0,0,0"
                            Command="{Binding DataContext.AccountList.RefreshCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Refresh (full list reload until Step 8 per-account refresh)">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRefresh}"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="12" Height="12" />
                            <TextBlock Text="Refresh" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- body — scrollable -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,12">

                    <!-- General -->
                    <StackPanel Margin="0,0,0,16">
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="GENERAL"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgTertiary}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource Accent}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="unsaved"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgTertiary}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Alias" FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchBoxStyle}"
                                 Margin="0,0,0,12" />

                        <TextBlock Text="Description" FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,4" />
                        <Border Background="{DynamicResource BgInput}"
                                BorderBrush="{DynamicResource BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource RadiusMd}"
                                Margin="0,0,0,12">
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource FgPrimary}"
                                     CaretBrush="{DynamicResource FgPrimary}"
                                     SelectionBrush="{DynamicResource AccentSubtleBg}"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"
                                     Padding="12,8"
                                     VerticalContentAlignment="Top" />
                        </Border>

                        <TextBlock Text="Group" FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,4" />
                        <ComboBox IsEditable="True" IsTextSearchEnabled="True"
                                  Text="{Binding Group, UpdateSourceTrigger=LostFocus}"
                                  ItemsSource="{Binding DataContext.AccountList.Groups,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                  Background="{DynamicResource BgInput}"
                                  BorderBrush="{DynamicResource BorderDefault}"
                                  Foreground="{DynamicResource FgPrimary}"
                                  Height="30"
                                  Margin="0,0,0,12" />

                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,4">
                            <Run Text="Tags" />
                            <Run Text=" (comma-separated)" Foreground="{DynamicResource FgTertiary}" />
                        </TextBlock>
                        <TextBox Text="{Binding TagsCsv, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchBoxStyle}"
                                 ToolTip="Edit tags as comma-separated list. Chip editor wired in Step 7.4."
                                 Margin="0,0,0,12" />

                        <CheckBox IsChecked="{Binding Disabled}"
                                  Content="Disabled (excluded from launches)"
                                  Foreground="{DynamicResource FgPrimary}"
                                  FontSize="13" />
                    </StackPanel>

                    <!-- Custom fields (read-only in v1) -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="CUSTOM FIELDS"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Fields}"
                                      Visibility="{Binding Fields.Count, Converter={StaticResource NullToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Key}"
                                                   FontFamily="{DynamicResource FontMono}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource FgSecondary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   FontFamily="{DynamicResource FontMono}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource FgPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(no custom fields)"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Fields.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Proxy section (editable, schema v2) -->
                    <Expander Margin="0,0,0,16"
                              Foreground="{DynamicResource FgPrimary}">
                        <Expander.Header>
                            <TextBlock Text="PROXY"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource FgTertiary}" />
                        </Expander.Header>
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox IsChecked="{Binding ProxyEnabled}"
                                      Content="Use custom proxy for this account"
                                      Foreground="{DynamicResource FgPrimary}"
                                      FontSize="13"
                                      Margin="0,0,0,12" />

                            <Grid IsEnabled="{Binding ProxyEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Type -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,8">
                                    <TextBlock Text="Type" FontSize="11"
                                               Foreground="{DynamicResource FgTertiary}"
                                               Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding AvailableProxyTypes}"
                                              SelectedItem="{Binding ProxyType}"
                                              Background="{DynamicResource BgInput}"
                                              BorderBrush="{DynamicResource BorderDefault}"
                                              Foreground="{DynamicResource FgPrimary}"
                                              Height="30" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,8">
                                    <TextBlock Text="Port" FontSize="11"
                                               Foreground="{DynamicResource FgTertiary}"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxStyle}"
                                             FontFamily="{DynamicResource FontMono}" />
                                </StackPanel>

                                <!-- Host (full width) -->
                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <TextBlock Text="Host" FontSize="11"
                                               Foreground="{DynamicResource FgTertiary}"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxStyle}"
                                             FontFamily="{DynamicResource FontMono}" />
                                </StackPanel>

                                <!-- Username -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,4,8">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource FgTertiary}"
                                               Margin="0,0,0,4">
                                        <Run Text="Username" />
                                        <Run Text="(optional)" Foreground="{DynamicResource FgTertiary}" />
                                    </TextBlock>
                                    <TextBox Text="{Binding ProxyUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxStyle}"
                                             FontFamily="{DynamicResource FontMono}" />
                                </StackPanel>

                                <!-- Password (PasswordBox — code-behind sync) -->
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="4,0,0,8">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource FgTertiary}"
                                               Margin="0,0,0,4">
                                        <Run Text="Password" />
                                        <Run Text="(optional)" Foreground="{DynamicResource FgTertiary}" />
                                    </TextBlock>
                                    <Border Background="{DynamicResource BgInput}"
                                            BorderBrush="{DynamicResource BorderDefault}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource RadiusMd}"
                                            Height="30">
                                        <PasswordBox x:Name="ProxyPasswordField"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource FgPrimary}"
                                                     CaretBrush="{DynamicResource FgPrimary}"
                                                     FontFamily="{DynamicResource FontMono}"
                                                     FontSize="13"
                                                     Padding="12,0"
                                                     VerticalContentAlignment="Center"
                                                     PasswordChanged="OnProxyPasswordChanged" />
                                    </Border>
                                </StackPanel>

                                <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgTertiary}"
                                           TextWrapping="Wrap"
                                           Text="Stored encrypted alongside the cookie. Excluded from plaintext exports." />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Window placement (read-only — driven by Account.WindowPlacement) -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="WINDOW PLACEMENT"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="X" FontSize="11"
                                           Foreground="{DynamicResource FgTertiary}" />
                                <TextBlock Text="{Binding WindowPlacement.X, FallbackValue='—', TargetNullValue='—'}"
                                           FontFamily="{DynamicResource FontMono}"
                                           FontSize="12"
                                           Foreground="{DynamicResource FgPrimary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="Y" FontSize="11"
                                           Foreground="{DynamicResource FgTertiary}" />
                                <TextBlock Text="{Binding WindowPlacement.Y, FallbackValue='—', TargetNullValue='—'}"
                                           FontFamily="{DynamicResource FontMono}"
                                           FontSize="12"
                                           Foreground="{DynamicResource FgPrimary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0">
                                <TextBlock Text="W" FontSize="11"
                                           Foreground="{DynamicResource FgTertiary}" />
                                <TextBlock Text="{Binding WindowPlacement.Width, FallbackValue='—', TargetNullValue='—'}"
                                           FontFamily="{DynamicResource FontMono}"
                                           FontSize="12"
                                           Foreground="{DynamicResource FgPrimary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="4,0,0,0">
                                <TextBlock Text="H" FontSize="11"
                                           Foreground="{DynamicResource FgTertiary}" />
                                <TextBlock Text="{Binding WindowPlacement.Height, FallbackValue='—', TargetNullValue='—'}"
                                           FontFamily="{DynamicResource FontMono}"
                                           FontSize="12"
                                           Foreground="{DynamicResource FgPrimary}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="(read-only in v1; editor in Step 7.4)"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgTertiary}"
                                   FontStyle="Italic"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Info -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgTertiary}"
                                   Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="UserId"
                                       FontSize="12" Foreground="{DynamicResource FgTertiary}"
                                       Margin="0,2,16,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding UserId}"
                                       FontFamily="{DynamicResource FontMono}"
                                       FontSize="12"
                                       Foreground="{DynamicResource FgPrimary}"
                                       Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Username"
                                       FontSize="12" Foreground="{DynamicResource FgTertiary}"
                                       Margin="0,2,16,2" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Username}"
                                       FontFamily="{DynamicResource FontMono}"
                                       FontSize="12"
                                       Foreground="{DynamicResource FgPrimary}"
                                       Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Created"
                                       FontSize="12" Foreground="{DynamicResource FgTertiary}"
                                       Margin="0,2,16,2" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Created, StringFormat='{}{0:MMM d, yyyy}'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource FgPrimary}"
                                       Margin="0,2" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last used"
                                       FontSize="12" Foreground="{DynamicResource FgTertiary}"
                                       Margin="0,2,16,2" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding LastUsed, StringFormat='{}{0:MMM d, yyyy HH:mm}', FallbackValue='—', TargetNullValue='—'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource FgPrimary}"
                                       Margin="0,2" />
                        </Grid>
                    </StackPanel>

                    <!-- Save bar -->
                    <Border BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,1,0,0"
                            Padding="0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="unsaved changes"
                                       FontSize="12"
                                       Foreground="{DynamicResource FgTertiary}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                            <Button Grid.Column="1" Style="{StaticResource BtnStyle}"
                                    Command="{Binding CancelCommand}"
                                    IsEnabled="{Binding IsDirty}"
                                    Margin="0,0,8,0"
                                    Content="Cancel" />
                            <Button Grid.Column="2"
                                    Command="{Binding ApplyChangesCommand}"
                                    IsEnabled="{Binding IsDirty}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BtnPrimaryStyle}" />
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconCheck}"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stretch="Uniform" Width="12" Height="12" />
                                    <TextBlock Text="Apply" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Delete account -->
                    <Button Margin="0,12,0,0"
                            Foreground="{DynamicResource StatusError}"
                            Command="{Binding DataContext.AccountList.DeleteAccountCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding DataContext.AccountList.SelectedItem,
                                                        RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnStyle}">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Delete account" Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
